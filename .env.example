# Qdrant Health Monitor Configuration

# Qdrant Server URL
# Format: http://host:port
# Default: http://localhost:6333
QDRANT_URL=http://localhost:6333

# API Key (if using Qdrant Cloud or authentication)
# Leave empty if not using authentication
QDRANT_API_KEY=

# Health Check Configuration
# Number of points to sample for analysis (lower = faster, less accurate)
SAMPLE_SIZE=1000

# Cosine similarity threshold for detecting near-duplicates (0-1)
# Default: 0.99 (very similar vectors)
SIMILARITY_THRESHOLD=0.99

# Output directory for Markdown reports
OUTPUT_DIR=./health_reports

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
